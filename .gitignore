#  PYTHON
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

#  ENVIRONNEMENTS VIRTUELS
env/
venv/
.venv/
.env
*.env

#  LOGS — tous les dossiers logs du projet
logs/
**/logs/
*.log

#  DONNEES BRUTES GENEREES (recalculables)
risk-scoring-engine/data/raw/
!risk-scoring-engine/data/raw/.gitkeep

#  DONNEES TRAITEES (recalculables)
risk-scoring-engine/data/processed/
!risk-scoring-engine/data/processed/.gitkeep

#  MODELES ML
risk-scoring-engine/models/*.pkl
risk-scoring-engine/models/*.joblib
# Garder uniquement les métadonnées légères
!risk-scoring-engine/models/pipeline_latest_meta.json
!risk-scoring-engine/models/.gitkeep

#  RAPPORTS GENERES (recalculables)
risk-scoring-engine/reports/*.html
risk-scoring-engine/reports/*.png
risk-scoring-engine/reports/*.csv
risk-scoring-engine/reports/*.json
!risk-scoring-engine/reports/.gitkeep

#  CACHE ET TESTS

.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
pip-log.txt
pip-delete-this-directory.txt

